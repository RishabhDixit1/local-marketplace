# ServiQ Staging Environment
# Copy to .env.staging and fill in values

# Supabase (staging project)
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Site URL
NEXT_PUBLIC_SITE_URL=https://staging.serviq.app

# Payment
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# AI
OPENAI_API_KEY=your-openai-key

# Email
RESEND_API_KEY=your-resend-key
BACKUP_EMAIL_API_KEY=your-backup-email-key

# Error tracking
SENTRY_DSN=your-sentry-dsn

# Push notifications
SERVIQ_INTERNAL_PUSH_KEY=your-push-key
VAPID_PUBLIC_KEY=your-vapid-public
VAPID_PRIVATE_KEY=your-vapid-private
VAPID_EMAIL=your-vapid-email

# Firebase
STAGING_FIREBASE_PROJECT_ID=your-staging-firebase-project
STAGING_FIREBASE_SERVICE_ACCOUNT_JSON=your-staging-service-account-json
