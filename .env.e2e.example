# Base app variables are loaded from .env.local.
# Copy this file to .env.e2e.local only if you plan to run authenticated Playwright tests.

# Required for authenticated Playwright runs when auto-generating a magic link
E2E_LOGIN_EMAIL=you@example.com

# Optional: set this if you already have a fresh magic link URL and want to skip generation
# E2E_MAGIC_LINK_URL=https://your-project-ref.supabase.co/auth/v1/verify?token=...

# Optional: enable the login request smoke step
# E2E_ENABLE_LOGIN_REQUEST_SMOKE=1
