# Required local app configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Recommended for full local server behavior
# Needed for server-side publish APIs, avatar uploads, startup diagnostics,
# and local E2E magic-link generation.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional admin-only startup diagnostics banner on /dashboard
# ADMIN_EMAIL_ALLOWLIST=you@example.com,teammate@example.com

# Optional observability forwarding
# OBSERVABILITY_FORWARD_URL=https://your-observability-endpoint.example.com
# OBSERVABILITY_FORWARD_TOKEN=your-observability-bearer-token
# NEXT_PUBLIC_OBSERVABILITY_DEBUG=1
# NEXT_PUBLIC_OBSERVABILITY_ENABLED=1
