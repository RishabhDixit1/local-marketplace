# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=<your-project-url>         # e.g. https://your-project.supabase.co
SUPABASE_URL=<your-project-url>                     # same as above
SUPABASE_STORAGE_URL=<your-project-url>/storage/v1  # storage endpoint
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>       # anon/public key from Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>   # service_role key (server-side only!)

# ── App metadata (optional) ──
APP_VERSION=0.0.0
APP_DOWNLOAD_URL=
APP_UPDATE_CRITICAL=false
APP_RELEASE_NOTES=

# ── AWS (for file uploads / S3) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2

# ── Firebase (for mobile push, optional) ──
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=serviq-mobile
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_ANDROID_APP_ID=
FIREBASE_IOS_APP_ID=

# ── AI / Search (optional) ──
GOOGLE_GEMINI_API_KEY=

# ── Email (Resend) ──
RESEND_API_KEY=re_<your-resend-api-key>

# ── Internal Auth (required for local session tokens) ──
SERVIQ_INTERNAL_PUSH_KEY=<your-random-secret-key>
