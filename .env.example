# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000
MOBILE_AUTH_REDIRECT_URLS=serviq://auth-callback

# Error Monitoring (Sentry)
# Get DSN from https://serviq.sentry.io
SENTRY_DSN=https://examplePublicKey@o123456.ingest.sentry.io/123456

# Email (Resend for transactional + fallback auth emails)
# Get key from https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Payments
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
# Webhook secret from Razorpay Dashboard > Settings > Webhooks
# Must match exactly — without it, payment webhooks will be rejected
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

# Push notifications
SERVIQ_INTERNAL_PUSH_KEY=replace-with-long-random-string
VAPID_PUBLIC_KEY=replace-with-web-push-public-key
VAPID_PRIVATE_KEY=replace-with-web-push-private-key
VAPID_EMAIL=ops@example.com
FIREBASE_PROJECT_ID=serviq-staging
# Prefer workload identity / GOOGLE_APPLICATION_CREDENTIALS in production.
# For staging-only local tests, this can hold the raw service account JSON.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}

# AI / LLM (OpenAI)
# Used by AI Launchpad, quote drafting, and intent parsing
OPENAI_API_KEY=sk-your-openai-api-key

# Internal Supabase URL (server-side only, not exposed to client)
# Set to your Supabase internal API URL (e.g., self-hosted EC2 URL or hosted URL)
SUPABASE_URL=http://localhost:54321

# Cron job authentication
# Shared secret verified by cron routes via x-cron-secret header.
# Must match the value set in Vercel Cron Jobs dashboard.
CRON_SECRET=replace-with-long-random-secret

# Admin email allowlist
# Comma-separated list of admin email addresses
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# Twilio (SMS/WhatsApp notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_SMS_FROM=+1234567890

# AWS SES (email) - optional fallback for Resend
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Backup email API key (fallback for critical notification failures)
BACKUP_EMAIL_API_KEY=your-backup-key

# Vercel Environment Variables Setup:
# Add these to your Vercel project dashboard at:
# Settings > Environment Variables
#
# For each variable:
# 1. Set scope to: Production, Preview, Development
# 2. Copy values from your Supabase dashboard
# 3. Save and redeploy
