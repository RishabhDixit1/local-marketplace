# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000
MOBILE_AUTH_REDIRECT_URLS=serviq://auth-callback

# Error Monitoring (Sentry)
# Get DSN from https://serviq.sentry.io
SENTRY_DSN=https://examplePublicKey@o123456.ingest.sentry.io/123456

# Payments
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret

# Push notifications
SERVIQ_INTERNAL_PUSH_KEY=replace-with-long-random-string
VAPID_PUBLIC_KEY=replace-with-web-push-public-key
VAPID_PRIVATE_KEY=replace-with-web-push-private-key
VAPID_EMAIL=ops@example.com
FIREBASE_PROJECT_ID=serviq-staging
# Prefer workload identity / GOOGLE_APPLICATION_CREDENTIALS in production.
# For staging-only local tests, this can hold the raw service account JSON.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}

# Vercel Environment Variables Setup:
# Add these to your Vercel project dashboard at:
# Settings > Environment Variables
#
# For each variable:
# 1. Set scope to: Production, Preview, Development
# 2. Copy values from your Supabase dashboard
# 3. Save and redeploy
